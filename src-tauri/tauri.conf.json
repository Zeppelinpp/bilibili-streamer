{
  "productName": "Bilibili-Streamer",
  "version": "1.0.5",
  "identifier": "com.bilistreamer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bilibili-Streamer",
        "width": 900,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500,
        "center": true,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Transparent"
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.bilibili.com https://*.bilivideo.com https://github.com https://*.github.com https://*.githubusercontent.com; img-src 'self' https://*.bilibili.com https://*.hdslb.com data:; script-src 'self'; style-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "dmg",
      "app",
      "appimage",
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyNUUyQjBEMzlEM0M4OUIKUldTYnlOTTVEU3RlTXFMSnRlMWtBdFdWS2tDV3hEc055ejFkcDArL0k2RjJCRExmYVQ1THJla3oK",
      "endpoints": [
        "https://github.com/Zeppelinpp/bilibili-streamer/releases/latest/download/latest.json"
      ]
    }
  }
}
